{
	"name": "@mattisvensson/strapi-plugin-webatlas",
	"description": "A strapi plugin to manage URL routes and navigations.",
	"license": "MIT",
	"version": "0.11.4",
	"keywords": [
		"strapi",
		"plugin",
		"webatlas",
		"navigation",
		"routes",
		"slug"
	],
	"type": "commonjs",
	"exports": {
		"./package.json": "./package.json",
		"./strapi-admin": {
			"types": "./dist/admin/src/index.d.ts",
			"source": "./admin/src/index.tsx",
			"import": "./dist/admin/index.mjs",
			"require": "./dist/admin/index.js",
			"default": "./dist/admin/index.js"
		},
		"./strapi-server": {
			"types": "./dist/server/src/index.d.ts",
			"source": "./server/src/index.ts",
			"import": "./dist/server/index.mjs",
			"require": "./dist/server/index.js",
			"default": "./dist/server/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "strapi-plugin build && yalc push --publish",
		"watch": "strapi-plugin watch",
		"watch:link": "strapi-plugin watch:link",
		"verify": "strapi-plugin verify",
		"test:ts:front": "tsc -p admin/tsconfig.json",
		"test:ts:back": "tsc -p server/tsconfig.json",
		"test:jest": "ENV_PATH=./playground/.env  jest --verbose --runInBand --forceExit",
		"test:cypress": "cypress run",
		"test:cypress:open": "cypress open",
		"preversion": "yarn build",
		"postversion": "git push && git push --tags"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2"
	},
	"devDependencies": {
		"@strapi/admin": "^5.42.1",
		"@strapi/content-manager": "^5.0.0",
		"@strapi/design-system": "^2.0.0",
		"@strapi/icons": "^2.0.0",
		"@strapi/pack-up": "^5.0.0",
		"@strapi/sdk-plugin": "^6.0.0",
		"@strapi/strapi": "^5.42.1",
		"@strapi/typescript-utils": "^5.0.0",
		"@strapi/utils": "^5.42.1",
		"@types/lodash": "^4",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"cypress": "^13.9.0",
		"cypress-terminal-report": "^6.0.2",
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"prettier": "^3.4.2",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"react-intl": "^6.0.0",
		"react-router-dom": "^6.0.0",
		"supertest": "^7.0.0",
		"typescript": "^5.7.2",
		"yalc": "^1.0.0-pre.53"
	},
	"peerDependencies": {
		"@strapi/admin": "^5.42.1",
		"@strapi/design-system": "^2.0.0",
		"@strapi/icons": "^2.0.0",
		"@strapi/strapi": "^5.42.1",
		"@strapi/utils": "^5.42.1",
		"react": "^17.0.0 || ^18.0.0",
		"react-dom": "^17.0.0 || ^18.0.0",
		"react-intl": "^6.0.0",
		"react-router-dom": "^6.0.0",
		"styled-components": "^6.0.0"
	},
	"strapi": {
		"name": "webatlas",
		"displayName": "Webatlas",
		"description": "A strapi plugin to manage URL routes and navigations.",
		"kind": "plugin"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/mattisvensson/strapi-plugin-webatlas.git"
	},
	"bugs": {
		"url": "https://github.com/mattisvensson/strapi-plugin-webatlas/issues"
	},
	"homepage": "https://github.com/mattisvensson/strapi-plugin-webatlas",
	"author": {
		"name": "Matti Svensson",
		"email": "mattisvensson@web.de",
		"url": "https://mattisvensson.dev"
	},
	"maintainers": [
		{
			"name": "Matti Svensson",
			"email": "mattisvensson@web.de",
			"url": "https://mattisvensson.dev"
		}
	],
	"engines": {
		"node": ">=22.x.x <=24.x.x",
		"npm": ">=6.0.0"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
